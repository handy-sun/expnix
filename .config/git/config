[user]
	email = handy-sun@foxmail.com
	name = sooncheer

[core]
	autocrlf = false
	safecrlf = true
	editor = vim
	# pager = less -FRSX

[pull]
	rebase = true

[diff]
	tool = vimdiff

[difftool "vimdiffc"]
	cmd = vimdiff \"$LOCAL\" \"$REMOTE\"

[difftool]
	prompt = false

[init]
	defaultBranch = master

## about git-delta
[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true ## use n and N to move between diff sections
	## delta detects terminal colors automatically; set one of these to disable auto-detection
	dark = true
	side-by-side = true

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default
