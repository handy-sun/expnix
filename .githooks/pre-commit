#!/usr/bin/env sh

# Get all staged Nix files (Added, Copied, Modified).
files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.nix$')
if [ -z "$files" ]; then
    exit 0
fi

echo "Checking staged .nix files with nixfmt..."
nixfmt --check $files || {
    echo "Nix files are not formatted. Run 'nixfmt' (or 'just nixfmt'), then stage the changes before committing."
    exit 1
}
