#!/usr/bin/env sh

# Get all staged Nix files (Added, Copied, Modified).
files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.nix$')
if [ -z "$files" ]; then
    exit 0
fi

echo "Checking staged .nix files with nix fmt..."
nix fmt -- --fail-on-change $files || {
    echo "Nix files are not formatted. Run 'nix fmt' and stage the changes before committing."
    exit 1
}
